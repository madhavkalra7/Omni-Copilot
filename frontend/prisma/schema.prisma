generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String?
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  tools         ToolConnection[]
  auditLogs     AuditLog[]
  memoryEntries MemoryEntry[]
}

model ToolConnection {
  id            String   @id @default(cuid())
  toolId        String
  label         String
  connected     Boolean  @default(false)
  encryptedAuth String?
  lastUsed      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, toolId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  undoable  Boolean  @default(false)
  undone    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model MemoryEntry {
  id         String   @id @default(cuid())
  key        String
  value      String
  vectorId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, key])
}
